---
// ExperimentDownloader.astro
// This component displays a card-based interface for downloading experiment notebooks and datasets
---

<div class="max-w-6xl mx-auto px-4 py-8">
  <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">
    Experiment Downloads
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    <div
      class="bg-white rounded-lg shadow-md p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1"
    >
      <h3 class="text-xl font-semibold text-gray-900 mb-3">Experiment 1:</h3>
      <div class="flex flex-col space-y-3">
        <a
          href="/rl/RL_Exp_1.ipynb"
          download
          class="flex items-center justify-center bg-blue-600 text-white font-medium py-2 px-4 rounded-md hover:bg-blue-700 transition-colors"
        >
          Download Notebook
        </a>
        <!-- <a href="/Housing.csv" download class="flex items-center justify-center bg-green-600 text-white font-medium py-2 px-4 rounded-md hover:bg-green-700 transition-colors">
          Download Dataset
